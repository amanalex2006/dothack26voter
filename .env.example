# Supabase PostgreSQL Connection String (Transaction Pooler or Direct Connection URI)
# Find this in Supabase -> Settings -> Database -> Connection Strings (choose URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Flask Session Security Key (can be any long random secret string)
FLASK_SECRET_KEY=some_long_random_secret_string

# Default Admin Account Password (defaults to admin123 if not set)
ADMIN_PASSWORD=admin123
